# Application Environment
# Options: development, staging, production
NODE_ENV=development

# Server Configuration
# Port on which the API server will run (default: 3000)
API_PORT=3000

# Base URL for API (used in image responses and CORS)
# For development: http://localhost:3000
# For production: https://api.yourdomain.com
API_BASE_URL=http://localhost:3000

# MongoDB Connection
# Format: mongodb+srv://<USERNAME>:<PASSWORD>@cluster.mongodb.net/<DATABASE>
MONGODB_URL=mongodb+srv://<USERNAME>:<PASSWORD>@cluster.mongodb.net/

# JWT Configuration
# Use a strong, random secret key - change in production
JET_SECRET_KEY=your-secret-key-here-change-in-production

# Cloudinary Configuration (for image uploads)
CLOUDINARY_CLOUD_NAME=your-cloud-name
CLOUDINARY_API_KEY=your-api-key
CLOUDINARY_API_SECRET=your-api-secret

# CORS Configuration
# This should match your frontend URL
# For development: http://localhost:5173 (Vite default port)
# For production: https://yourdomain.com
CORS_ORIGIN=http://localhost:5173
